#!/bin/bash
set -euo pipefail

cd "$(dirname "$0")/.."

JEKYLL_HOST_PORT="${JEKYLL_HOST_PORT:-8081}"
JEKYLL_LIVERELOAD_PORT="${JEKYLL_LIVERELOAD_PORT:-35729}"

docker build -t naturedesk-jekyll-local .
docker run --rm -it \
  -p "${JEKYLL_HOST_PORT}:8080" \
  -p "${JEKYLL_LIVERELOAD_PORT}:35729" \
  -v "$PWD:/srv/jekyll" \
  -w /srv/jekyll \
  naturedesk-jekyll-local \
  bundle exec jekyll serve --host 0.0.0.0 --port 8080 --livereload --livereload-port 35729
