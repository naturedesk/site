# runner.env.example — config-stage placeholder for BON Spark ARM64 rehearsal
#
# Purpose:
# - This file exists so a clean checkout can run `docker compose config --quiet`.
# - It is NOT a production runtime env file.
# - Do not put secrets in this example file.
#
# Usage for config-stage rehearsal:
#   cp /path/to/bon-in-a-box-spark-dockers/env/runner.env.example pipeline-repo/runner.env
#
# If the Compose model warns about HPC variables, use env/hpc-secrets.env.example
# and dummy local files for config-only validation. Real HPC credentials must never
# be committed.

# Add real runner settings only when following upstream/runtime instructions.
