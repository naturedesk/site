# hpc-secrets.env.example — dummy local paths for config-stage rehearsal only
#
# Purpose:
# - Prevent Compose from resolving unset HPC secret file variables to the project directory.
# - These paths are safe dummy placeholders for `docker compose config --quiet`.
# - They are NOT real HPC credentials.
#
# Usage:
#   mkdir -p .naturedesk-dummy-secrets
#   touch .naturedesk-dummy-secrets/hpc_ssh_key \
#         .naturedesk-dummy-secrets/hpc_known_hosts \
#         .naturedesk-dummy-secrets/hpc_ssh_config
#   chmod 600 .naturedesk-dummy-secrets/hpc_ssh_key
#   cp /path/to/bon-in-a-box-spark-dockers/env/hpc-secrets.env.example .hpc-secrets.env
#
# Then include:
#   --env-file .hpc-secrets.env

HPC_SSH_KEY=.naturedesk-dummy-secrets/hpc_ssh_key
HPC_KNOWN_HOSTS_FILE=.naturedesk-dummy-secrets/hpc_known_hosts
HPC_SSH_CONFIG_FILE=.naturedesk-dummy-secrets/hpc_ssh_config
