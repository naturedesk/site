diff --git a/script-server/Dockerfile.dev b/script-server/Dockerfile.dev
index 8bfaaae..389693c 100644
--- a/script-server/Dockerfile.dev
+++ b/script-server/Dockerfile.dev
@@ -2,12 +2,27 @@ FROM gradle:9.0-jdk21
 
 #INSTALL DOCKER CLI
 ENV DOCKER_VERSION=29.1.2
-RUN curl -sfL -o docker.tgz "https://download.docker.com/linux/static/stable/x86_64/docker-${DOCKER_VERSION}.tgz" && \
+ARG TARGETARCH
+RUN arch="${TARGETARCH}"; \
+  if [ -z "$arch" ]; then arch="$(dpkg --print-architecture)"; fi; \
+  case "$arch" in \
+    amd64) docker_arch="x86_64"; compose_arch="x86_64" ;; \
+    arm64) docker_arch="aarch64"; compose_arch="aarch64" ;; \
+    *) echo "Unsupported TARGETARCH: $arch" >&2; exit 1 ;; \
+  esac; \
+  curl -sfL -o docker.tgz "https://download.docker.com/linux/static/stable/${docker_arch}/docker-${DOCKER_VERSION}.tgz" && \
   tar -xzf docker.tgz docker/docker --strip=1 && \
   mv docker /usr/local/bin && \
   rm docker.tgz
 
-RUN curl -L "https://github.com/docker/compose/releases/download/v2.3.3/docker-compose-linux-x86_64" -o /usr/local/bin/docker-compose
+RUN arch="${TARGETARCH}"; \
+  if [ -z "$arch" ]; then arch="$(dpkg --print-architecture)"; fi; \
+  case "$arch" in \
+    amd64) compose_arch="x86_64" ;; \
+    arm64) compose_arch="aarch64" ;; \
+    *) echo "Unsupported TARGETARCH: $arch" >&2; exit 1 ;; \
+  esac; \
+  curl -L "https://github.com/docker/compose/releases/download/v2.3.3/docker-compose-linux-${compose_arch}" -o /usr/local/bin/docker-compose
 RUN chmod 755 /usr/local/bin/docker-compose
 RUN chmod 755 /usr/local/bin/docker
 
